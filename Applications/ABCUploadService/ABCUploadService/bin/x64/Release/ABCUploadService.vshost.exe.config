<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!--log source is for event log source-->
    <add key="log source" value="ABCUploadService"/>
    <add key="log" value="Application"/>
    <add key="trace" value="Y"/>
    <add key="environment" value="dev"/>
    <add key="connection" value="user id=bizmod_api;password=Integration_B2B!;data source=abisd1"/>
    <add key="filter" value="*.csv" />
    <add key="path" value="C:\Upload"/>

  </appSettings>
  <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
    </startup>
</configuration>