{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"2"},
           "H2":{"TEXT":"<<HEADING>>","FORMAT":"@","JUSTIFIED":"CENTER","START":"3","END":"7"},
           "H3":{"TEXT":"<<START_DATE>> - <<END_DATE>>","FORMAT":"@","JUSTIFIED":"RIGHT","START":"8","END":"10"}
		  },
 "HEADINGS":{"OfficeName":{"TEXT":"District Office","JUSTIFIED":"CENTER","LENGTH":"30"},
             "objectdefname":{"TEXT":"Job Type","JUSTIFIED":"CENTER","LENGTH":"20"},
             "licensenumber":{"TEXT":"License Number","JUSTIFIED":"CENTER","LENGTH":"10"},
			 "description":{"TEXT":"Description","JUSTIFIED":"CENTER","LENGTH":"12"},
             "transactiondate":{"TEXT":"Transaction Date","JUSTIFIED":"CENTER","LENGTH":"12"},
             "paidamountadjusted":{"TEXT":"Paid Amount","JUSTIFIED":"CENTER","LENGTH":"12"},
             "feeamount":{"TEXT":"Fee Amount","JUSTIFIED":"CENTER","LENGTH":"12"},
             "balancedue":{"TEXT":"Balance Due","JUSTIFIED":"CENTER","LENGTH":"12"},
			 "status":{"TEXT":"Status","JUSTIFIED":"CENTER","LENGTH":"10"},
             "feeid":{"TEXT":"I.T. Fee Identifier","JUSTIFIED":"CENTER","LENGTH":"12"}
		  },
 "COLUMNS":{"OfficeName":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "objectdefname":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "licensenumber":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "description":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "transactiondate":{"FORMAT":"mm/dd/yyyy","JUSTIFIED":"LEFT"},
            "paidamountadjusted":{"FORMAT":"######0.00","JUSTIFIED":"RIGHT"},
            "feeamount":{"FORMAT":"######0.00","JUSTIFIED":"RIGHT"},
            "balancedue":{"FORMAT":"######0.00","JUSTIFIED":"RIGHT"},
            "status":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "feeid":{"FORMAT":"#########0","JUSTIFIED":"RIGHT"}
		  }
}

