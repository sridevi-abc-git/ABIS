{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"1"},
           "H2":{"TEXT":"<<HEADING>>","FORMAT":"@","JUSTIFIED":"CENTER","START":"2","END":"2"},
           "H3":{"TEXT":"<<START_DATE>> - <<END_DATE>>","FORMAT":"@","JUSTIFIED":"RIGHT","START":"3","END":"3"}
		  },
 "HEADINGS":{"DIV":{"TEXT":" ","JUSTIFIED":"CENTER","LENGTH":"20"},
			 "PRL":{"TEXT":" ","JUSTIFIED":"CENTER","LENGTH":"60"},
			 "PRE":{"TEXT":" ","JUSTIFIED":"CENTER","LENGTH":"15"}
		  },
 "COLUMNS":{"DIV":{"COLUMN_NUMBER":"1","JUSTIFIED":"RIGHT","FORMAT":"@"},
			"PRL":{"COLUMN_NUMBER":"2","JUSTIFIED":"LEFT","FORMAT":"@"},
			"PRE":{"COLUMN_NUMBER":"3","JUSTIFIED":"RIGHT","FORMAT":"0"}
		  }
}


