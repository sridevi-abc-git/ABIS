{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"1"},
           "H2":{"TEXT":"<<HEADING>>","FORMAT":"@","JUSTIFIED":"CENTER","START":"2","END":"3"},
           "H3":{"TEXT":"<<START_DATE>> - <<END_DATE>>","FORMAT":"@","JUSTIFIED":"RIGHT","START":"4","END":"5"}
		  },
 "COLUMNS":{"OFFICE":{"COLUMN_NUMBER":"1","JUSTIFIED":"LEFT","FORMAT":"@"},
			"PERMIT":{"COLUMN_NUMBER":"2","JUSTIFIED":"RIGHT","FORMAT":"0"},
			"TEMPBERRWINE":{"COLUMN_NUMBER":"3","JUSTIFIED":"RIGHT","FORMAT":"0"},
			"GENERAL":{"COLUMN_NUMBER":"4","JUSTIFIED":"RIGHT","FORMAT":"0"},
			"CATERING":{"COLUMN_NUMBER":"5","JUSTIFIED":"RIGHT","FORMAT":"0"}
		  }
}


