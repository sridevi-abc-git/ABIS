{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"1"},
           "H2":{"TEXT":"<<HEADING>>","FORMAT":"@","JUSTIFIED":"CENTER","START":"2","END":"4"},
           "H3":{"TEXT":"<<START_DATE>> - <<END_DATE>>","FORMAT":"@","JUSTIFIED":"RIGHT","START":"5","END":"5"}
		  },
 "HEADINGS":{"LICENSENUMBER":{"TEXT":"License Number","JUSTIFIED":"CENTER","LENGTH":"20"},
             "ISSUEDATE":{"TEXT":"Issue Date","JUSTIFIED":"CENTER","LENGTH":"20"},
             "OFFICENAME":{"TEXT":"Office","JUSTIFIED":"CENTER","LENGTH":"30"},
             "APPLICATIONTYPE":{"TEXT":"Application Type","JUSTIFIED":"CENTER","LENGTH":"20"},
             "TRANSFERTYPE":{"TEXT":"Transfer Type","JUSTIFIED":"CENTER","LENGTH":"50"}
		  },
 "COLUMNS":{"LICENSENUMBER":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "ISSUEDATE":{"FORMAT":"mm/dd/yyyy","JUSTIFIED":"LEFT"},
            "OFFICENAME":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "APPLICATIONTYPE":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "TRANSFERTYPE":{"FORMAT":"@","JUSTIFIED":"LEFT"}
		  }
}

