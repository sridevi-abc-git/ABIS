{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"1"},
           "H2":{"TEXT":"<<REPORT_NAME>>","FORMAT":"@","JUSTIFIED":"CENTER","START":"2","END":"10"}
		  },
 "HEADINGS":{"COUNTYNAME":{"TEXT":"County Name","JUSTIFIED":"CENTER","LENGTH":"20"},
             "CENSUSTRACT":{"TEXT":"Census Tract","JUSTIFIED":"CENTER","LENGTH":"15"},
             "ONSALEALLOWED":{"TEXT":"On-Sale Allowed","JUSTIFIED":"CENTER","LENGTH":"10"},
             "OFFSALEALLOWED":{"TEXT":"Off-Sale Allowed","JUSTIFIED":"CENTER","LENGTH":"10"},
             "ONSALEOFFSALE":{"TEXT":"On-Sale / Off-Sale","JUSTIFIED":"CENTER","LENGTH":"10"},
             "LICENSENUMBER":{"TEXT":"License Number","JUSTIFIED":"CENTER","LENGTH":"10"},
             "LICENSETYPECODE":{"TEXT":"License Type","JUSTIFIED":"CENTER","LENGTH":"5"},
             "STATUSNAME":{"TEXT":"Status","JUSTIFIED":"CENTER","LENGTH":"10"},
             "PRIMARYLICENSEE":{"TEXT":"Licensee","JUSTIFIED":"CENTER","LENGTH":"50"},
             "PREMISEADDRESS":{"TEXT":"Premise Address","JUSTIFIED":"CENTER","LENGTH":"70"}
		  },
 "COLUMNS":{"COUNTYNAME":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "CENSUSTRACT":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "ONSALEALLOWED":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "OFFSALEALLOWED":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "ONSALEOFFSALE":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "LICENSENUMBER":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "LICENSETYPECODE":{"FORMAT":"00","JUSTIFIED":"RIGHT"},
            "STATUSNAME":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "PRIMARYLICENSEE":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "PREMISEADDRESS":{"FORMAT":"@","JUSTIFIED":"LEFT"}
		  }
}

