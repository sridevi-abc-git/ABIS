{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"2"},
           "H2":{"TEXT":"<<REPORT_NAME>>","FORMAT":"@","JUSTIFIED":"CENTER","START":"3","END":"5"}
		  },
 "HEADINGS":{"PAYMENTDATE":{"TEXT":"Payment Date","JUSTIFIED":"CENTER","LENGTH":"25"},
             "LICENSENUMBER":{"TEXT":"License Number","JUSTIFIED":"CENTER","LENGTH":"10"},
             "LICENSETYPECODES":{"TEXT":"License Types","JUSTIFIED":"CENTER","LENGTH":"20"},
             "CONFIRMATIONNUMBER":{"TEXT":"Confirmation Id","JUSTIFIED":"CENTER","LENGTH":"20"},
             "PAYAMOUNT":{"TEXT":"Payment Amount","JUSTIFIED":"CENTER","LENGTH":"15"},
             "RECEIPTNUMBER":{"TEXT":"Receipt Number","JUSTIFIED":"CENTER","LENGTH":"10"},
             "TRANSMITTALBATCH":{"TEXT":"Transmittal Batch","JUSTIFIED":"CENTER","LENGTH":"15"},
             "DEPOSITBATCHID":{"TEXT":"Deposit Batch","JUSTIFIED":"CENTER","LENGTH":"15"}
		  },
 "COLUMNS":{"PAYMENTDATE":{"FORMAT":"mm/dd/yyyy h:mm:ss AM/PM","JUSTIFIED":"LEFT"},
             "LICENSENUMBER":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
             "LICENSETYPECODES":{"FORMAT":"00","JUSTIFIED":"RIGHT"},
             "CONFIRMATIONNUMBER":{"FORMAT":"##############","JUSTIFIED":"RIGHT"},
             "PAYAMOUNT":{"FORMAT":"###,###,###,##0.00","JUSTIFIED":"RIGHT"},
             "TRANSMITTALBATCH":{"FORMAT":"##########","JUSTIFIED":"RIGHT"},
             "DEPOSITBATCHID":{"FORMAT":"##########","JUSTIFIED":"RIGHT"}
		  }
}
