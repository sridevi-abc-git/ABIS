{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"2"},
           "H2":{"TEXT":"<<REPORT_NAME>>","FORMAT":"@","JUSTIFIED":"CENTER","START":"3","END":"5"},
           "H3":{"TEXT":"<<START_DATE>> - <<END_DATE>>","FORMAT":"@","JUSTIFIED":"RIGHT","START":"6","END":"7"}
		  },
 "HEADINGS":{"LICENSENUMBER":{"TEXT":"License Number","JUSTIFIED":"CENTER","LENGTH":"10"},
             "LIC_APP_STATUS":{"TEXT":"License App Status","JUSTIFIED":"CENTER","LENGTH":"20"},
             "LICENSETYPECODE":{"TEXT":"License Type","JUSTIFIED":"CENTER","LENGTH":"10"},
             "TYPE_STATUS":{"TEXT":"Status Type","JUSTIFIED":"CENTER","LENGTH":"10"},
             "STATUS_DATE":{"TEXT":"Status Date","JUSTIFIED":"CENTER","LENGTH":"11"},
             "PRIMARYLICENSEE":{"TEXT":"Primary Licensee","JUSTIFIED":"CENTER","LENGTH":"50"},
             "LICENSETYPES_STATUS":{"TEXT":"License Type Status","JUSTIFIED":"CENTER","LENGTH":"15"}
		  },
 "COLUMNS":{"LICENSENUMBER":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
             "LIC_APP_STATUS":{"FORMAT":"@","JUSTIFIED":"LEFT"},
             "LICENSETYPECODE":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
             "TYPE_STATUS":{"FORMAT":"@","JUSTIFIED":"LEFT"},
             "STATUS_DATE":{"FORMAT":"mm/dd/yyyy","JUSTIFIED":"CENTER"},
             "PRIMARYLICENSEE":{"FORMAT":"@","JUSTIFIED":"LEFT"},
             "LICENSETYPES_STATUS":{"FORMAT":"@","JUSTIFIED":"LEFT"}
		  }
}
