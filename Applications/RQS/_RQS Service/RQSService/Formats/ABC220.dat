{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"1"},
           "H2":{"TEXT":"ABC 220 Report","FORMAT":"@","JUSTIFIED":"CENTER","START":"2","END":"9"},
           "H3":{"TEXT":"<<START_DATE>> - <<END_DATE>>","FORMAT":"@","JUSTIFIED":"RIGHT","START":"10","END":"13"}
		  },
 "HEADINGS":{"APPLICATIONCOMPLETEDDATE":{"TEXT":"Entered Application Completed","JUSTIFIED":"CENTER","LENGTH":"20"},
             "LICENSENUMBER":{"TEXT":"License Number","JUSTIFIED":"CENTER","LENGTH":"10"},
             "OFFICE":{"TEXT":"Dist Office","JUSTIFIED":"CENTER","LENGTH":"20"},
			 "LICENSEE":{"TEXT":"Licensee","JUSTIFIED":"CENTER","LENGTH":"50"},
             "ADDRESS":{"TEXT":"Address","JUSTIFIED":"CENTER","LENGTH":"70"},
			 "LICENSETYPECODE":{"TEXT":"License Type Code","JUSTIFIED":"CENTER","LENGTH":"10"},
			 "APPLICATION":{"TEXT":"Application Type","JUSTIFIED":"CENTER","LENGTH":"11"},
			 "TRANSFERTYPE":{"TEXT":"Transfer Type","JUSTIFIED":"CENTER","LENGTH":"40"},
			 "APPREVIEWCOMPLETED":{"TEXT":"Dist App Review Completed","JUSTIFIED":"CENTER","LENGTH":"10"},
			 "COMPLETEDDATE":{"TEXT":"Completed Date","JUSTIFIED":"CENTER","LENGTH":"13"},
			 "STATUS":{"TEXT":"Status","JUSTIFIED":"CENTER","LENGTH":"10"},
			 "OUTCOME":{"TEXT":"Outcome","JUSTIFIED":"CENTER","LENGTH":"9"},
			 "DAYSPENDING":{"TEXT":"Days Pending","JUSTIFIED":"CENTER","LENGTH":"8"}
		  },
 "COLUMNS":{"APPLICATIONCOMPLETEDDATE":{"COLUMN_NUMBER":"1","JUSTIFIED":"LEFT","FORMAT":"mm/dd/yyyy"},
            "LICENSENUMBER":{"COLUMN_NUMBER":"2","JUSTIFIED":"RIGHT","FORMAT":"@"},
            "OFFICE":{"COLUMN_NUMBER":"3","JUSTIFIED":"LEFT","FORMAT":"00"},
			"LICENSEE":{"COLUMN_NUMBER":"4","JUSTIFIED":"LEFT","FORMAT":"@"},
            "ADDRESS":{"COLUMN_NUMBER":"5","JUSTIFIED":"LEFT","FORMAT":"@"},
			"LICENSETYPECODE":{"COLUMN_NUMBER":"6","JUSTIFIED":"RIGHT","FORMAT":"@"},
			"APPLICATION":{"COLUMN_NUMBER":"7","JUSTIFIED":"LEFT","FORMAT":"@"},
			"TRANSFERTYPE":{"COLUMN_NUMBER":"8","JUSTIFIED":"LEFT","FORMAT":"@"},
			"APPREVIEWCOMPLETED":{"COLUMN_NUMBER":"9","JUSTIFIED":"LEFT","FORMAT":"mm/dd/yyyy"},
			"COMPLETEDDATE":{"COLUMN_NUMBER":"10","JUSTIFIED":"LEFT","FORMAT":"mm/dd/yyyy"},
			"STATUS":{"COLUMN_NUMBER":"11","JUSTIFIED":"LEFT","FORMAT":"@"},
			"OUTCOME":{"COLUMN_NUMBER":"12","JUSTIFIED":"LEFT","FORMAT":"@"},
			"DAYSPENDING":{"COLUMN_NUMBER":"13","JUSTIFIED":"RIGHT","FORMAT":"@"}
