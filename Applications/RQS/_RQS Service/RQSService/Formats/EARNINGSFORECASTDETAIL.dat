{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"1"},
           "H2":{"TEXT":"Earnings Forecast Report (Detail)","FORMAT":"@","JUSTIFIED":"CENTER","START":"2","END":"16"},
           "H3":{"TEXT":"<<START_DATE>>","FORMAT":"mm/dd/yyyy","JUSTIFIED":"RIGHT","START":"17","END":"19"}
		  },
 "HEADINGS":{"jobid":{"TEXT":"ID","JUSTIFIED":"CENTER","LENGTH":"20"},
             "licensenumber":{"TEXT":"License Number","JUSTIFIED":"CENTER","LENGTH":"10"},
             "effectivedate":{"TEXT":"Expiration Date","JUSTIFIED":"CENTER","LENGTH":"15"},
			 "ltcode":{"TEXT":"License Type Code","JUSTIFIED":"CENTER","LENGTH":"10"},
