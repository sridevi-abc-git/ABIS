			 "bpufee":{"TEXT":"BPU Fee","JUSTIFIED":"CENTER","LENGTH":"10"}
		  },
 "COLUMNS":{"jobid":{"COLUMN_NUMBER":"1","JUSTIFIED":"RIGHT","FORMAT":"###0"},
            "licensenumber":{"COLUMN_NUMBER":"2","JUSTIFIED":"RIGHT","FORMAT":"@"},
