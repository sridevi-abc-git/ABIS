{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"2"},
           "H2":{"TEXT":"<<HEADING>>","FORMAT":"@","JUSTIFIED":"CENTER","START":"3","END":"15"},
           "H3":{"TEXT":"<<START_DATE>> - <<END_DATE>>","FORMAT":"@","JUSTIFIED":"RIGHT","START":"16","END":"18"}
		  },
 "HEADINGS":{"LICENSE_NUM":{"TEXT":"License Number","JUSTIFIED":"CENTER","LENGTH":"10"},
             "LICENSE_TYPE_CODE":{"TEXT":"License Type","JUSTIFIED":"CENTER","LENGTH":"10"},
             "FROMSTATUS":{"TEXT":"From Status","JUSTIFIED":"CENTER","LENGTH":"10"},
             "TOSTATUS":{"TEXT":"To Status","JUSTIFIED":"CENTER","LENGTH":"10"},
             "EFFECTIVEDATE":{"TEXT":"Status Date","JUSTIFIED":"CENTER","LENGTH":"10"},
             "APP_OR_LIC":{"TEXT":"Type","JUSTIFIED":"CENTER","LENGTH":"5"},
             "STATICLABEL":{"TEXT":"Primary Secondary","JUSTIFIED":"CENTER","LENGTH":"10"},
             "DUP_COUNT":{"TEXT":"Dup Count","JUSTIFIED":"CENTER","LENGTH":"10"},
             "ORIG_ISS_DATE":{"TEXT":"Original Issue Date","JUSTIFIED":"CENTER","LENGTH":"10"},
             "EXPIR_DATE":{"TEXT":"Expiration Date","JUSTIFIED":"CENTER","LENGTH":"10"},
             "DBA":{"TEXT":"DBA","JUSTIFIED":"CENTER","LENGTH":"50"},
             "PRIMARY_OWNER":{"TEXT":"Licensee","JUSTIFIED":"CENTER","LENGTH":"50"},
             "PREM_ADDR":{"TEXT":"Premise Address 1","JUSTIFIED":"CENTER","LENGTH":"50"},
             "PREM_CSZ":{"TEXT":"Premise Address 2","JUSTIFIED":"CENTER","LENGTH":"40"},
             "TRANSFER_TO":{"TEXT":"Transfer To","JUSTIFIED":"CENTER","LENGTH":"10"},
             "TRANSFER_FROM":{"TEXT":"Transfer From","JUSTIFIED":"CENTER","LENGTH":"10"},
             "DISTRICT_CODE":{"TEXT":"District Code","JUSTIFIED":"CENTER","LENGTH":"10"},
             "GEO_CODE":{"TEXT":"Geocode","JUSTIFIED":"CENTER","LENGTH":"10"}
		  },
 "COLUMNS":{"LICENSE_NUM":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "LICENSE_TYPE_CODE":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "FROMSTATUS":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "TOSTATUS":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "EFFECTIVEDATE":{"FORMAT":"mm/dd/yyyy","JUSTIFIED":"LEFT"},
            "APP_OR_LIC":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "STATICLABEL":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "DUP_COUNT":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "ORIG_ISS_DATE":{"FORMAT":"mm/dd/yyyy","JUSTIFIED":"LEFT"},
            "EXPIR_DATE":{"FORMAT":"mm/dd/yyyy","JUSTIFIED":"LEFT"},
            "DBA":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "PRIMARY_OWNER":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "PREM_ADDR":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "PREM_CSZ":{"FORMAT":"@","JUSTIFIED":"LEFT"},
            "TRANSFER_TO":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "TRANSFER_FROM":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "DISTRICT_CODE":{"FORMAT":"@","JUSTIFIED":"RIGHT"},
            "GEO_CODE":{"FORMAT":"@","JUSTIFIED":"RIGHT"}
		  }
}

