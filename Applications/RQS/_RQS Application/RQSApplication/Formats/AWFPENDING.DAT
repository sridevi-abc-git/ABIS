{"HEADER":{"H1":{"TEXT":"<<REPORT_DATE>>","FORMAT":"mm/dd/yyyy hh:mm AM/PM","JUSTIFIED":"LEFT","START":"1","END":"3"},
           "H2":{"TEXT":"<<REPORT_NAME>>","FORMAT":"@","JUSTIFIED":"CENTER","START":"4","END":"7"}
		  },
 "HEADINGS":{"paymentmethod":{"TEXT":"Payment Method","JUSTIFIED":"CENTER","LENGTH":"10"},
			 "licensenumber":{"TEXT":"License Number","JUSTIFIED":"CENTER","LENGTH":"10"},
			 "ltcode":{"TEXT":"License Type Code","JUSTIFIED":"CENTER","LENGTH":"7"},
			 "submitteddate":{"TEXT":"Transaction Date","JUSTIFIED":"CENTER","LENGTH":"12"},
			 "gallonage":{"TEXT":"Gallonage","JUSTIFIED":"CENTER","LENGTH":"15"},
			 "feerequired":{"TEXT":"Fee Required","JUSTIFIED":"CENTER","LENGTH":"10"},
			 "previouspayment":{"TEXT":"Previous Payment","JUSTIFIED":"CENTER","LENGTH":"10"},
			 "amountdue":{"TEXT":"Amount Due","JUSTIFIED":"CENTER","LENGTH":"10"},
			 "paid":{"TEXT":"Paid","JUSTIFIED":"CENTER","LENGTH":"10"},
			 "confirmationid":{"TEXT":"Confirmation Id","JUSTIFIED":"CENTER","LENGTH":"25"},
			 "status":{"TEXT":"Status","JUSTIFIED":"CENTER","LENGTH":"20"}
		  },
 "COLUMNS":{"paymentmethod":{"COLUMN_NUMBER":"1","JUSTIFIED":"LEFT","FORMAT":"@"},
			"licensenumber":{"COLUMN_NUMBER":"2","JUSTIFIED":"RIGHT","FORMAT":"@"},
			"ltcode":{"COLUMN_NUMBER":"3","JUSTIFIED":"RIGHT","FORMAT":"00"},
            "submitteddate":{"COLUMN_NUMBER":"4","JUSTIFIED":"RIGHT","FORMAT":"mm/dd/yyyy"},
			"gallonage":{"COLUMN_NUMBER":"5","JUSTIFIED":"RIGHT","FORMAT":"###,###,##0"},
			"feerequired":{"COLUMN_NUMBER":"6","JUSTIFIED":"RIGHT","FORMAT":"###,###,##0.00"},
			"previouspayment":{"COLUMN_NUMBER":"7","JUSTIFIED":"RIGHT","FORMAT":"###,###,##0.00"},
			"amountdue":{"COLUMN_NUMBER":"8","JUSTIFIED":"RIGHT","FORMAT":"###,###,##0.00"},
			"paid":{"COLUMN_NUMBER":"9","JUSTIFIED":"RIGHT","FORMAT":"###,###,##0.00"},
            "confirmationid":{"COLUMN_NUMBER":"10","JUSTIFIED":"RIGHT","FORMAT":"######################"},
			"status":{"COLUMN_NUMBER":"11","JUSTIFIED":"LEFT","FORMAT":"@"}
		  }
}


