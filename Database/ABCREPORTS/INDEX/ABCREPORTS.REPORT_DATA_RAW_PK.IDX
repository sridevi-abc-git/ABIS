DROP INDEX ABCREPORTS.REPORT_DATA_RAW_PK;

CREATE UNIQUE INDEX ABCREPORTS.REPORT_DATA_RAW_PK ON ABCREPORTS.REPORT_DATA_RAW
(SEQ)
LOGGING
TABLESPACE SMALL_ENC_INDEX
