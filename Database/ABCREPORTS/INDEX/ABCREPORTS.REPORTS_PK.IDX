DROP INDEX ABCREPORTS.REPORTS_PK;

CREATE UNIQUE INDEX ABCREPORTS.REPORTS_PK ON ABCREPORTS.REPORTS
(SEQ)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
