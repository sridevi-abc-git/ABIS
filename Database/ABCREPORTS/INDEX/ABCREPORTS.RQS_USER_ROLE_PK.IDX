DROP INDEX ABCREPORTS.RQS_USER_ROLE_PK;

CREATE UNIQUE INDEX ABCREPORTS.RQS_USER_ROLE_PK ON ABCREPORTS.RQS_USER_ROLE
(USER_ID)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
