DROP TABLE ABCREPORTS.LONG_BEACH_DATA_EXTRACT CASCADE CONSTRAINTS;

CREATE GLOBAL TEMPORARY TABLE ABCREPORTS.LONG_BEACH_DATA_EXTRACT
(
  TYPE_IND    VARCHAR2(1 BYTE),
  FILENUM     VARCHAR2(40 BYTE),
  RECORDTYPE  VARCHAR2(1 BYTE),
  RECORDSEQ   NUMBER(2),
  DETAILS     VARCHAR2(3600 BYTE)
)
ON COMMIT DELETE ROWS
NOCACHE;
