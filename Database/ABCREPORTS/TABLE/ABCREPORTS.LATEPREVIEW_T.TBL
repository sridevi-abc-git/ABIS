DROP TABLE ABCREPORTS.LATEPREVIEW_T CASCADE CONSTRAINTS;

CREATE GLOBAL TEMPORARY TABLE ABCREPORTS.LATEPREVIEW_T
(
  JOBID              NUMBER,
  FEEID              NUMBER(9),
  TRANSACTIONTYPEID  NUMBER(9),
  TRANSACTIONID      NUMBER(9),
  FEEOBJID           NUMBER,
  PAYMENTOBJECTID    NUMBER
)
ON COMMIT DELETE ROWS
NOCACHE;
