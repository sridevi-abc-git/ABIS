DROP TABLE ABCLQS.TEST_BLOB CASCADE CONSTRAINTS;

CREATE TABLE ABCLQS.TEST_BLOB
(
  REPORT_NUMBER  NUMBER,
  REPORT_NAME    VARCHAR2(50 BYTE),
  CREATEDDATE    DATE                           DEFAULT SYSDATE,
  REPORT_DATA    BLOB
)
LOB (REPORT_DATA) STORE AS SECUREFILE (
  TABLESPACE  LARGE_ENC_DATA
  ENABLE      STORAGE IN ROW
  CHUNK       8192
  RETENTION
  NOCACHE
  LOGGING
  STORAGE    (
              INITIAL          104K
              NEXT             1M
              MINEXTENTS       1
              MAXEXTENTS       UNLIMITED
              PCTINCREASE      0
              BUFFER_POOL      DEFAULT
             ))
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
