DROP TABLE ABCLQS.TEST_XML CASCADE CONSTRAINTS;

CREATE TABLE ABCLQS.TEST_XML
(
  RPTTYPE      VARCHAR2(40 BYTE),
  XML_TYPE     SYS.XMLTYPE,
  REPORT_DATA  BLOB,
  P_MESSAGE    VARCHAR2(4000 BYTE)
)
LOB (REPORT_DATA) STORE AS SECUREFILE (
  TABLESPACE  LARGE_ENC_DATA
  ENABLE      STORAGE IN ROW
  CHUNK       8192
  RETENTION
  NOCACHE
  LOGGING
  STORAGE    (
              INITIAL          104K
              NEXT             1M
              MINEXTENTS       1
              MAXEXTENTS       UNLIMITED
              PCTINCREASE      0
              BUFFER_POOL      DEFAULT
             ))
XMLTYPE XML_TYPE STORE AS SECUREFILE BINARY XML (
  TABLESPACE  LARGE_ENC_DATA
  ENABLE      STORAGE IN ROW
  CHUNK       8192
  RETENTION
  NOCACHE
  LOGGING
  STORAGE    (
              INITIAL          104K
              NEXT             1M
              MINEXTENTS       1
              MAXEXTENTS       UNLIMITED
              PCTINCREASE      0
              BUFFER_POOL      DEFAULT
             ))
ALLOW NONSCHEMA
DISALLOW ANYSCHEMA
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
