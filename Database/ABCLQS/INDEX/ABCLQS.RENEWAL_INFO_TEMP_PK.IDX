DROP INDEX ABCLQS.RENEWAL_INFO_TEMP_PK;

CREATE UNIQUE INDEX ABCLQS.RENEWAL_INFO_TEMP_PK ON ABCLQS.RENEWAL_INFO_TEMP
(LICENSENUMBER, LICENSETYPECODE, EXPIRATIONDATE)
LOGGING
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
