CREATE OR REPLACE FUNCTION ABCLQS.GetEscrow
( p_JobId INTEGER)
RETURN XMLTYPE
IS
  l_XML XMLTYPE;
  
BEGIN

SELECT
  XMLELEMENT("ESCROW", SUBSTR(E.ESCROWCOMPANYNAME||', '||E.ADDRESSLINE1||' '||E.ADDRESSLINE2||' '||E.USCITY||','||E.USSTATE||' '||E.ZIPCODE,1,250) )  
INTO l_xml
FROM MART.ESCROW E 
JOIN MART.APPLICATIONESCROW A ON E.OBJECTID = A.ESCROWOBJECTID
WHERE A.APPLICATIONOBJECTID = p_JobId;
  
RETURN l_XML;
END GetEscrow;
/
