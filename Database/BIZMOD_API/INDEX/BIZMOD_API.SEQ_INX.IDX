DROP INDEX BIZMOD_API.SEQ_INX;

CREATE UNIQUE INDEX BIZMOD_API.SEQ_INX ON BIZMOD_API.ESERVICES_LOG_T
(SEQ)
LOGGING
TABLESPACE API_ENC_DATA
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
