DROP INDEX ABC.FILENUM_ISS_INDX;

CREATE INDEX ABC.FILENUM_ISS_INDX ON ABC.LATEPREVIEW_ISSUE_RPT
(FILENUM)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
