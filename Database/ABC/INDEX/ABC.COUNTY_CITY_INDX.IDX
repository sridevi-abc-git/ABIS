DROP INDEX ABC.COUNTY_CITY_INDX;

CREATE INDEX ABC.COUNTY_CITY_INDX ON ABC.POPULATIONS
(COUNTY_CITY)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
