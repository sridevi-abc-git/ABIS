DROP INDEX ABC.SELF_CERTIFICATION_PK;

CREATE UNIQUE INDEX ABC.SELF_CERTIFICATION_PK ON ABC.SELF_CERTIFICATION
(LICENSENUMBER, LICENSETYPECODE, EXPIRATIONDATE)
LOGGING
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
