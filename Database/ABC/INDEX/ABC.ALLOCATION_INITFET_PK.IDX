DROP INDEX ABC.ALLOCATION_INITFET_PK;

CREATE UNIQUE INDEX ABC.ALLOCATION_INITFET_PK ON ABC.ALLOCATION_INITIALFETCH
(RECORD_NUM, LICENSENUMBER, ISMASTER, FEEACTIVITY)
LOGGING
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
