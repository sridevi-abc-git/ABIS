DROP INDEX ABC.BTJOBID_INDX1;

CREATE INDEX ABC.BTJOBID_INDX1 ON ABC.AREV_TEST
(BTJOBID)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
