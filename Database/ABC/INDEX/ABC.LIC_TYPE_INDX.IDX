DROP INDEX ABC.LIC_TYPE_INDX;

CREATE INDEX ABC.LIC_TYPE_INDX ON ABC.RAWDATADUMP_T
(TYPE_TYPE)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
