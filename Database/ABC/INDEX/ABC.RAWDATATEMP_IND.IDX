DROP INDEX ABC.RAWDATATEMP_IND;

CREATE INDEX ABC.RAWDATATEMP_IND ON ABC.RAWDATAEXTRACT_TYPE_FTB_TEMP
(LICOBJECTID)
LOGGING
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
