DROP INDEX ABC.STAFF_PK;

CREATE UNIQUE INDEX ABC.STAFF_PK ON ABC.STAFFS
(STAFF_ID)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
