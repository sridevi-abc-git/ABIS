DROP INDEX ABC.LICENSENUMBER_INDX;

CREATE INDEX ABC.LICENSENUMBER_INDX ON ABC.RAWDATADUMP_T
(LICENSENUMBER)
LOGGING
TABLESPACE SMALL_ENC_INDEX
