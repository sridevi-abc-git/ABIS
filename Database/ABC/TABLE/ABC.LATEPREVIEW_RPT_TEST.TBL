DROP TABLE ABC.LATEPREVIEW_RPT_TEST CASCADE CONSTRAINTS;

CREATE TABLE ABC.LATEPREVIEW_RPT_TEST
(
  FILENUM       NUMBER(9),
  LICENSEE      VARCHAR2(100 BYTE),
  STATUS        VARCHAR2(10 BYTE),
  DISTRICT      VARCHAR2(50 BYTE),
  LTCODE        VARCHAR2(5 BYTE),
  LTSTATUS      VARCHAR2(50 BYTE),
  LTEXPDATE     DATE,
  LTFEECODE     VARCHAR2(10 BYTE),
  AMTTYPE       VARCHAR2(5 BYTE),
  MI            VARCHAR2(5 BYTE),
  DUP           NUMBER(3),
  TRANSFEECODE  VARCHAR2(15 BYTE),
  TRANSCODE     VARCHAR2(15 BYTE),
  TRANSAMT      NUMBER(9,2),
  TRANSDATE     DATE,
  TRANSTYPE     VARCHAR2(5 BYTE),
  EXPDATE       DATE,
  REPORTDATE    DATE
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;


CREATE INDEX ABC.FILENUM_INDX1 ON ABC.LATEPREVIEW_RPT_TEST
(FILENUM)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );

GRANT DELETE, INSERT, SELECT, UPDATE ON ABC.LATEPREVIEW_RPT_TEST TO POSSEEXTENSIONS;

GRANT DELETE, INSERT, SELECT, UPDATE ON ABC.LATEPREVIEW_RPT_TEST TO PUBLIC;
