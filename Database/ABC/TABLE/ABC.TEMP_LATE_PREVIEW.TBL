DROP TABLE ABC.TEMP_LATE_PREVIEW CASCADE CONSTRAINTS;

CREATE TABLE ABC.TEMP_LATE_PREVIEW
(
  OBJECTID   NUMBER,
  AMOUNTDUE  NUMBER
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
