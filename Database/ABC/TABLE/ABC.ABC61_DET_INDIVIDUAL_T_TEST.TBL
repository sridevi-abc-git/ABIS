DROP TABLE ABC.ABC61_DET_INDIVIDUAL_T_TEST CASCADE CONSTRAINTS;

CREATE TABLE ABC.ABC61_DET_INDIVIDUAL_T_TEST
(
  INVESTIGATOR  VARCHAR2(60 BYTE),
  LOGDATE       DATE,
  INVCOMMENTS   VARCHAR2(4000 BYTE),
  STARTTIME     VARCHAR2(4 BYTE),
  ENDTIME       VARCHAR2(4 BYTE),
  OBJECTID      NUMBER(9),
  RPTOBJECTID   NUMBER(9)
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;


GRANT SELECT ON ABC.ABC61_DET_INDIVIDUAL_T_TEST TO POSSEEXTENSIONS;
