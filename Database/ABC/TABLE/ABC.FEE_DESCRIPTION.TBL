DROP TABLE ABC.FEE_DESCRIPTION CASCADE CONSTRAINTS;

CREATE TABLE ABC.FEE_DESCRIPTION
(
  FEEACTIVITY      VARCHAR2(10 BYTE),
  FEE_DESCRIPTION  VARCHAR2(40 BYTE)
)
TABLESPACE SMALL_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
