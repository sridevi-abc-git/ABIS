DROP TABLE ABC.B_TEXT_TEST CASCADE CONSTRAINTS;

CREATE TABLE ABC.B_TEXT_TEST
(
  T_JOBID1            NUMBER,
  T_PTFEEOBJECTLIST1  NUMBER
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
