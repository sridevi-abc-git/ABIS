DROP TABLE ABC.LATE_PENALTIES CASCADE CONSTRAINTS;

CREATE GLOBAL TEMPORARY TABLE ABC.LATE_PENALTIES
(
  PAYSTATUS   VARCHAR2(20 BYTE),
  TRANSCODE   VARCHAR2(10 BYTE),
  LTCODE      VARCHAR2(10 BYTE),
  MASTER_IND  VARCHAR2(1 BYTE),
  AMOUNT      NUMBER
)
ON COMMIT DELETE ROWS
NOCACHE;


GRANT SELECT ON ABC.LATE_PENALTIES TO POSSEEXTENSIONS;
