DROP TABLE ABC.AREV_TEST CASCADE CONSTRAINTS;

CREATE TABLE ABC.AREV_TEST
(
  EXPIREDT      DATE,
  LICENSENUM    VARCHAR2(4000 BYTE),
  LICSTATUS     VARCHAR2(4000 BYTE),
  PRIMLICENSEE  VARCHAR2(4000 BYTE),
  PREMADDR2LNS  VARCHAR2(4000 BYTE),
  LTCODE        VARCHAR2(4000 BYTE),
  LTSTATUS      VARCHAR2(100 BYTE),
  LTSTATUSDT    DATE,
  LTJOBID       NUMBER(9),
  LICJOBID      NUMBER(9),
  BTJOBID       NUMBER(9),
  BATCHTYPE     VARCHAR2(4000 BYTE),
  SLTOBJID      NUMBER(9)
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;


CREATE INDEX ABC.BTJOBID_INDX1 ON ABC.AREV_TEST
(BTJOBID)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );

CREATE INDEX ABC.LTSTATUS_INDX1 ON ABC.AREV_TEST
(LTSTATUS)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );

GRANT DELETE, INSERT, SELECT, UPDATE ON ABC.AREV_TEST TO POSSEEXTENSIONS;

GRANT DELETE, INSERT, SELECT, UPDATE ON ABC.AREV_TEST TO PUBLIC;
