DROP TABLE ABC.ABC61_T_TEST CASCADE CONSTRAINTS;

CREATE TABLE ABC.ABC61_T_TEST
(
  PREMADD            VARCHAR2(200 BYTE),
  PREMADD1           VARCHAR2(4000 BYTE),
  SUBJ               VARCHAR2(50 BYTE),
  LICNUM             VARCHAR2(40 BYTE),
  PDBA               VARCHAR2(4000 BYTE),
  ITYPE              VARCHAR2(100 BYTE),
  INVNO              VARCHAR2(50 BYTE),
  ASSGNDATE          DATE,
  ORIGIN             VARCHAR2(100 BYTE),
  ORIGINTYPE         VARCHAR2(100 BYTE),
  OFFC               VARCHAR2(4000 BYTE),
  OFFCCODE           VARCHAR2(3 BYTE),
  TYPECODE           VARCHAR2(4000 BYTE),
  CMPTYP             VARCHAR2(100 BYTE),
  ADMINTYP           VARCHAR2(100 BYTE),
  TTYPE              VARCHAR2(4000 BYTE),
  CMPDATE            DATE,
  OBJECTID           NUMBER(9),
  ASSGNDTO           VARCHAR2(4000 BYTE),
  ASSGNINSTRUCTIONS  VARCHAR2(4000 BYTE),
  ABC61DATE          DATE,
  TYPE_DET           VARCHAR2(4000 BYTE),
  RPTOBJECTID        NUMBER(9),
  PRIORITY           VARCHAR2(100 BYTE),
  COMPLETEDDT        DATE
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;


GRANT ALTER, DELETE, INSERT, SELECT, UPDATE, ON COMMIT REFRESH, QUERY REWRITE, DEBUG, FLASHBACK ON ABC.ABC61_T_TEST TO POSSEEXTENSIONS;
