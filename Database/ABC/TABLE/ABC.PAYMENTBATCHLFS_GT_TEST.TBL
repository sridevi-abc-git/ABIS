DROP TABLE ABC.PAYMENTBATCHLFS_GT_TEST CASCADE CONSTRAINTS;

CREATE TABLE ABC.PAYMENTBATCHLFS_GT_TEST
(
  AMOUNT       NUMBER(15,2)                     NOT NULL,
  FEEACTIVITY  VARCHAR2(4000 BYTE),
  ISOVR        VARCHAR2(4000 BYTE)
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
