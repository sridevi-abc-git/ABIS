DROP TABLE ABC.CONDITIONS_TEST CASCADE CONSTRAINTS;

CREATE TABLE ABC.CONDITIONS_TEST
(
  CONDITIONCODE               VARCHAR2(20 BYTE),
  CONDITIONTEXT               VARCHAR2(4000 BYTE),
  TEXTTYPE                    VARCHAR2(100 BYTE),
  ACTIVE                      VARCHAR2(1 BYTE),
  SORT1                       NUMBER,
  APPLICATIONLICENSE          VARCHAR2(1 BYTE),
  ONEDAY                      VARCHAR2(1 BYTE),
  CATEREREVENTAUTHORIZATION   VARCHAR2(1 BYTE),
  ISPREAMBLE                  VARCHAR2(1 BYTE),
  ISCONDITION                 VARCHAR2(1 BYTE),
  PERTOPERFIDUCIARYTRANSFERS  VARCHAR2(1 BYTE)
)
TABLESPACE SMALL_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          128K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
