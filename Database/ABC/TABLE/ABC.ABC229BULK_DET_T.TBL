DROP TABLE ABC.ABC229BULK_DET_T CASCADE CONSTRAINTS;

CREATE GLOBAL TEMPORARY TABLE ABC.ABC229BULK_DET_T
(
  OBJECTID   NUMBER(9)                          NOT NULL,
  JOBID      NUMBER(9)                          NOT NULL,
  EVENTDATE  DATE                               NOT NULL,
  SUMMARY    VARCHAR2(4000 BYTE)
)
ON COMMIT DELETE ROWS
NOCACHE;


GRANT ALTER, DELETE, INSERT, SELECT, UPDATE, ON COMMIT REFRESH, QUERY REWRITE, DEBUG, FLASHBACK ON ABC.ABC229BULK_DET_T TO POSSEEXTENSIONS;
