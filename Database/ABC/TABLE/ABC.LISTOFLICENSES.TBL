DROP TABLE ABC.LISTOFLICENSES CASCADE CONSTRAINTS;

CREATE TABLE ABC.LISTOFLICENSES
(
  LICENSE_NUMBER  NUMBER,
  LICENSE_TYPE    NUMBER
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
