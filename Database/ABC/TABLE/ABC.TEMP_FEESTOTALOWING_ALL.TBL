DROP TABLE ABC.TEMP_FEESTOTALOWING_ALL CASCADE CONSTRAINTS;

CREATE TABLE ABC.TEMP_FEESTOTALOWING_ALL
(
  CODE              VARCHAR2(1 BYTE),
  FEE_OBJECTID      NUMBER(9),
  LIC_JOBID         NUMBER(9)                   NOT NULL,
  LIC_NUMBER        VARCHAR2(40 BYTE),
  LICENSETYPECODE   VARCHAR2(3 BYTE),
  TRANSACTIONDATE   DATE,
  DESCRIPTION       VARCHAR2(60 BYTE),
  AMOUNTFORDISPLAY  NUMBER,
  TOTALOWING        NUMBER,
  F_AMOUNT          NUMBER,
  F_ADJUSTEDAMOUNT  NUMBER,
  F_PAIDAMOUNT      NUMBER
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
