DROP TABLE ABC.ABC220LOG_T_TEST CASCADE CONSTRAINTS;

CREATE TABLE ABC.ABC220LOG_T_TEST
(
  FROM_DATE  DATE,
  THRU_DATE  DATE,
  EMP        VARCHAR2(1000 BYTE),
  RESULT     VARCHAR2(1000 BYTE),
  ACTIVE     VARCHAR2(1 BYTE),
  LICENSEE   VARCHAR2(1000 BYTE),
  LICNUM     VARCHAR2(40 BYTE),
  COMMENTS   VARCHAR2(1000 BYTE),
  OBJECTID   NUMBER(9)
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
