DROP TABLE ABC.US_STATES CASCADE CONSTRAINTS;

CREATE TABLE ABC.US_STATES
(
  STATE  VARCHAR2(40 BYTE),
  ABBR   VARCHAR2(2 BYTE)
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
