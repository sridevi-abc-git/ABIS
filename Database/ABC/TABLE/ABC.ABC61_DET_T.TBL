DROP TABLE ABC.ABC61_DET_T CASCADE CONSTRAINTS;

CREATE GLOBAL TEMPORARY TABLE ABC.ABC61_DET_T
(
  INVESTIGATOR  VARCHAR2(60 BYTE),
  LOGDATE       DATE,
  INVCOMMENTS   VARCHAR2(4000 BYTE),
  STARTTIME     VARCHAR2(4 BYTE),
  ENDTIME       VARCHAR2(4 BYTE),
  OBJECTID      NUMBER(9),
  RPTOBJECTID   NUMBER(9)
)
ON COMMIT DELETE ROWS
NOCACHE;


GRANT ALTER, DELETE, INSERT, SELECT, UPDATE, ON COMMIT REFRESH, QUERY REWRITE, DEBUG, FLASHBACK ON ABC.ABC61_DET_T TO POSSEEXTENSIONS;
