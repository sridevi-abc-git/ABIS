DROP TABLE ABC.MORATORIUM_COUNTY_COUNTS CASCADE CONSTRAINTS;

CREATE TABLE ABC.MORATORIUM_COUNTY_COUNTS
(
  COUNTY  VARCHAR2(50 BYTE),
  COUNT   NUMBER
)
TABLESPACE LARGE_ENC_DATA
PCTFREE    10
INITRANS   1
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           )
LOGGING 
NOCOMPRESS 
NOCACHE;
