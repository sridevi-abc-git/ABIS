CREATE OR REPLACE FORCE VIEW ABC.V_FEES
(FEEID, JOBID, LICENSETYPECODE, FEE_DESCRIPTION, DESCRIPTION, 
 AMOUNT, TAXAMOUNT, ADJUSTEDAMOUNT, ADJUSTEDTAXES, PAID, 
 PAIDTAXES, TRANSACTIONDATE)
BEQUEATH DEFINER
AS 
SELECT 
  FEEID
, JOBID
, SUBSTR(DESCRIPTION,1,2) LICENSETYPECODE
, SUBSTR(DESCRIPTION,6) FEE_DESCRIPTION
, DESCRIPTION
, Amount
, taxamount
, adjustedamount
, adjustedtaxes
, PAIDAMOUNT * -1 PAID
, paidtaxes
, TRANSACTIONDATE 
FROM API.FEES;
