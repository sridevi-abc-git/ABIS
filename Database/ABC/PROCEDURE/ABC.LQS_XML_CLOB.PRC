CREATE OR REPLACE PROCEDURE ABC.LQS_XML_CLOB
( p_qry IN VARCHAR2, p_RowTag VARCHAR2, p_xml OUT CLOB )
IS
  ctx DBMS_XMLGEN.ctxHandle;
BEGIN
--  DBMS_OUTPUT.PUT_LINE(p_qry);
  ctx := DBMS_XMLGEN.NEWCONTEXT(p_qry);
  DBMS_XMLGEN.SETROWSETTAG(ctx, NULL);
  DBMS_XMLGEN.SETROWTAG(ctx, p_RowTag);  -- 'LICENSEE_INFO'
  p_xml := DBMS_XMLGEN.GETXML(ctx);

--  DBMS_OUTPUT.PUT_LINE(p_qry);

END;
/
