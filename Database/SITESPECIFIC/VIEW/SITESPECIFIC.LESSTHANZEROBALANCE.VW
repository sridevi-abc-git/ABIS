CREATE OR REPLACE FORCE VIEW SITESPECIFIC.LESSTHANZEROBALANCE
(JOBID, BALANCE, OVR, LASTUPDATED, ERRORMSG, 
 NEEDSPROCESSING)
BEQUEATH DEFINER
AS 
select jobid, balance, ovr, lastupdated, errormsg, needsprocessing from lessthanzerobalance_t;


GRANT SELECT ON SITESPECIFIC.LESSTHANZEROBALANCE TO POSSEEXTENSIONS;
