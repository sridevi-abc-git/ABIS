                               WHERE x.month = 'Jul'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Aug'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Sep'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Oct'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Nov'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Dec'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Jan'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Feb'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Mar'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Apr'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'May'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Jun'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0)
                    FROM xtable g
                GROUP BY 2
                UNION ALL
                  SELECT 'IMPACT / ROSTIF INSPECTIONS',
                         'Off Sale',
                         NVL((SELECT SUM(x.totaloffsale)
                                FROM xtable x
                               WHERE x.fiscalyear = t_prevfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totaloffsale)
                                FROM xtable x
                               WHERE x.month = 'Jul'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totaloffsale)
                                FROM xtable x
                               WHERE x.month = 'Aug'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totaloffsale)
                                FROM xtable x
                               WHERE x.month = 'Sep'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
