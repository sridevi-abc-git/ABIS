    /*-------------------------------------------------------------------------
     * GAPMonthlySummaryReport() - Public
     * This procedure inserts rows into sitespecific.ABCMonthlySummary_gt
     * for the TRACE/LEAD GAP Agency Monthly Sumary Report
     *------------------------------------------------------------------------*/
    PROCEDURE gapmonthlysummaryreport(a_objectid udt_id)
    IS
        t_objects             api.udt_objectlist;
        t_unfilteredobjects   api.udt_objectlist;
        t_prevfiscalyear      NUMBER(4);
        t_currfiscalyear      NUMBER(4);
        t_agencyid            NUMBER(10);
        t_reportmonth         VARCHAR2(40);
        t_reportyear          NUMBER(4);
        t_agencyname          VARCHAR2(4000);
        t_rowcount            NUMBER(10);
    BEGIN
        t_unfilteredobjects   := api.udt_objectlist();

        SELECT sr.month, sr.year
          INTO t_reportmonth, t_reportyear
          FROM query.o_tl_grantmonthlysummaryreport sr
         --join api.relationships r on r.fromobjectid = sr.objectid
         -- join query.o_Tl_Agency ag on ag.objectid = r.ToObjectId
         WHERE sr.objectid = a_objectid;

        --Set the fiscal year for the report based on the report month
        IF t_reportmonth NOT IN ('JANUARY',
                                 'FEBUARY',
                                 'MARCH',
                                 'APRIL',
                                 'MAY',
                                 'JUNE') THEN
            t_currfiscalyear   := t_reportyear;
            t_prevfiscalyear   := t_reportyear - 1;
        ELSE
            t_currfiscalyear   := t_reportyear - 1;
            t_prevfiscalyear   := t_reportyear - 2;
        END IF;

        --clear the Global Temp Table (GTT) for this session
        DELETE sitespecific.abcmonthlysummary_gt;

        COMMIT;

        extension.pkg_cxproceduralsearch.initializesearch('o_TL_GrantData');
        extension.pkg_cxproceduralsearch.searchbyindex(
            'DateOfOperation',
            TO_DATE('07' || t_prevfiscalyear, 'mmyyyy'),
            TO_DATE('06' || (t_currfiscalyear + 1), 'mmyyyy'));
        --extension.pkg_cxproceduralsearch.SearchByIndex('GAPAgency', 'Y', null);
        extension.pkg_cxproceduralsearch.filterobjects('GAPAgency',
                                                       'Y',
                                                       NULL,
                                                       FALSE);
        extension.pkg_cxproceduralsearch.filterobjects('Submitted',
                                                       'Y',
                                                       NULL,
                                                       FALSE);
        extension.pkg_cxproceduralsearch.performsearch(t_unfilteredobjects,
                                                       'and',
                                                       'none');
        t_objects             := t_unfilteredobjects;

        --Get a row with a count of records for every category grouped by month
        FOR p
            IN (WITH
                    xtable
                    AS
                        (SELECT gd.objectid,
                                TO_CHAR(gd.dateofoperation, 'Mon')
                                    month,
                                (CASE
                                     WHEN TO_CHAR(gd.dateofoperation, 'mm') >=
                                          7 THEN
                                         TO_NUMBER(
                                             TO_CHAR(gd.dateofoperation,
                                                     'yyyy'))
                                     ELSE
                                           TO_NUMBER(
                                               TO_CHAR(gd.dateofoperation,
                                                       'yyyy'))
                                         - 1
                                 END)
                                    fiscalyear,
                                gd.granttype,
                                gd.totalofonsale
                                    totalofonsale,
                                gd.totaloffsale
                                    totaloffsale,
                                gd.totalviolation
                                    totalofviolations,
                                gd.totalofoffsaleviolation
                                    totaloffsaleviolation,
                                gd.totalofonsaleviolation
                                    totalonsaleviolation,
                                gd.totalofcontacts
                                    totalofcontacts,
                                gd.totaloflicenses
                                    totaloflicenses,
                                gd.totalofcitations
                                    totalofcitations,
                                gd.totalofbookings
                                    totalofbookings,
                                gd.onsale
                                    onsalevisited,
                                gd.offsale
                                    offsalevisited,
                                gd.numberofidschecked
                                    idschecked,
                                gd.numberofpeoplecited
                                    peoplecited,
                                gd.numberofpeoplebooked
                                    peoplebooked
                           FROM query.o_tl_grantdata  gd
                                JOIN TABLE(t_objects) u
                                    ON u.objectid = gd.objectid)
                  SELECT 'OVERALL ARRESTS'
                             category,
                         'Bookings'
                             subcategory,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.fiscalyear = t_prevfiscalyear),
                             0)
                             py,                     --change to temp variable
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Jul'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             jul,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Aug'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             aug,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Sep'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             sep,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Oct'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             oct,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Nov'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             nov,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Dec'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             dec,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Jan'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             jan,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Feb'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             feb,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Mar'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             mar,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Apr'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             apr,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'May'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             may,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.month = 'Jun'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0)
                             jun,
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplebooked, 0))
                                      + SUM(NVL(x.totalofbookings, 0)))
                                FROM xtable x
                               WHERE x.fiscalyear = t_currfiscalyear),
                             0)
                             ytd
                    FROM xtable g
                GROUP BY 2
                UNION ALL
                  SELECT 'OVERALL ARRESTS',
                         'Citations',
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.fiscalyear = t_prevfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Jul'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Aug'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Sep'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Oct'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Nov'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Dec'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Jan'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Feb'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Mar'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Apr'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'May'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.month = 'Jun'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT (  SUM(NVL(x.peoplecited, 0))
                                      + SUM(NVL(x.totalofcitations, 0))
                                      + SUM(NVL(x.totaloffsaleviolation, 0))
                                      + SUM(NVL(x.totalonsaleviolation, 0)))
                                FROM xtable x
                               WHERE x.fiscalyear = t_currfiscalyear),
                             0)
                    FROM xtable g
                GROUP BY 2
                UNION ALL
                  SELECT 'OVERALL ARRESTS',
                         'Total Arrests',
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.fiscalyear = t_prevfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Jul'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Aug'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Sep'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Oct'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Nov'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Dec'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Jan'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Feb'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Mar'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Apr'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'May'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.month = 'Jun'
                                 AND x.fiscalyear = t_currfiscalyear),
                             0),
                         NVL(
                             (SELECT   (  SUM(NVL(x.peoplecited, 0))
                                        + SUM(NVL(x.totalofcitations, 0))
                                        + SUM(NVL(x.totaloffsaleviolation, 0))
                                        + SUM(NVL(x.totalonsaleviolation, 0)))
                                     + SUM(NVL(x.peoplebooked, 0))
                                     + SUM(NVL(x.totalofbookings, 0))
                                FROM xtable x
                               WHERE x.fiscalyear = t_currfiscalyear),
                             0)
                    FROM xtable g
                GROUP BY 2
                UNION ALL
                  SELECT 'OVERALL OPERATIONS CONDUCTED',
                         'Minor Decoy',
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.fiscalyear = t_prevfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Jul'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Aug'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Sep'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Oct'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Nov'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Dec'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Jan'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Feb'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Mar'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Apr'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'May'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Jun'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0)
                    FROM xtable g
                GROUP BY 2
                UNION ALL
                  SELECT 'OVERALL OPERATIONS CONDUCTED',
                         'Shoulder Tap',
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.fiscalyear = t_prevfiscalyear
                                 AND x.granttype = 'Shoulder Tap'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Jul'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Shoulder Tap'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Aug'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Shoulder Tap'),
                             0),
                         NVL((SELECT COUNT(*)
                                FROM xtable x
                               WHERE x.month = 'Sep'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Shoulder Tap'),
                             0),
