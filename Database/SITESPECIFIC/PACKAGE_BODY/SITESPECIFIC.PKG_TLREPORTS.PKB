                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totaloffsale)
                                FROM xtable x
                               WHERE x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0)
                    FROM xtable g
                GROUP BY 2
                UNION ALL
                  SELECT 'IMPACT / ROSTIF INSPECTIONS',
                         'Total Inspections',
                         NVL((SELECT SUM(x.totalofonsale) + SUM(x.totaloffsale)
                                FROM xtable x
                               WHERE x.fiscalyear = t_prevfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale) + SUM(x.totaloffsale)
                                FROM xtable x
                               WHERE x.month = 'Jul'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale) + SUM(x.totaloffsale)
                                FROM xtable x
                               WHERE x.month = 'Aug'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale) + SUM(x.totaloffsale)
                                FROM xtable x
                               WHERE x.month = 'Sep'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
