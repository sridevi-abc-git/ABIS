                                         END,
                                         1)
                                FROM xtable x
                               WHERE x.month = 'Dec'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL(
                             (SELECT ROUND(
                                         CASE
                                             WHEN SUM(x.totalofviolations) > 0 THEN
                                                   (  SUM(x.totalofviolations)
                                                    / (  SUM(x.totalofonsale)
                                                       + SUM(x.totaloffsale)))
                                                 * 100
                                             ELSE
                                                 0
                                         END,
                                         1)
                                FROM xtable x
                               WHERE x.month = 'Jan'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL(
                             (SELECT ROUND(
                                         CASE
                                             WHEN SUM(x.totalofviolations) > 0 THEN
                                                   (  SUM(x.totalofviolations)
                                                    / (  SUM(x.totalofonsale)
                                                       + SUM(x.totaloffsale)))
                                                 * 100
                                             ELSE
                                                 0
                                         END,
                                         1)
                                FROM xtable x
                               WHERE x.month = 'Feb'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'Minor Decoy'),
                             0),
                         NVL(
                             (SELECT ROUND(
                                         CASE
