                                FROM xtable x
                               WHERE x.month = 'Jan'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Feb'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
                         NVL((SELECT SUM(x.totalofonsale)
                                FROM xtable x
                               WHERE x.month = 'Mar'
                                 AND x.fiscalyear = t_currfiscalyear
                                 AND x.granttype = 'IMPACT'),
                             0),
