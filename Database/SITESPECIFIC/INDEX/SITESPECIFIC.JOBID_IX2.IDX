DROP INDEX SITESPECIFIC.JOBID_IX2;

CREATE INDEX SITESPECIFIC.JOBID_IX2 ON SITESPECIFIC.LICENSEBATCHLOGGING_T
(JOBID)
LOGGING
TABLESPACE LARGE_ENC_DATA
