DROP INDEX SITESPECIFIC.INTERNETUSERS_PK;

CREATE UNIQUE INDEX SITESPECIFIC.INTERNETUSERS_PK ON SITESPECIFIC.INTERNETUSERS_T
(USERID)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             40K
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
