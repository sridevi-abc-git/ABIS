DROP INDEX SITESPECIFIC.CONFIGCOPYSESSIONS_UK_1;

CREATE UNIQUE INDEX SITESPECIFIC.CONFIGCOPYSESSIONS_UK_1 ON SITESPECIFIC.CONFIGCOPYSESSIONS
(CLASSID, SOURCEINSTANCEID, TARGETINSTANCEID)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
