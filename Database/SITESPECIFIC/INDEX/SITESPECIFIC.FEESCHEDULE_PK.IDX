DROP INDEX SITESPECIFIC.FEESCHEDULE_PK;

CREATE UNIQUE INDEX SITESPECIFIC.FEESCHEDULE_PK ON SITESPECIFIC.FEESCHEDULE_T
(OBJECTID)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
