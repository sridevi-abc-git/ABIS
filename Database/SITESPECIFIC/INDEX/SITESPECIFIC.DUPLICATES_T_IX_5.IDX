DROP INDEX SITESPECIFIC.DUPLICATES_T_IX_5;

CREATE INDEX SITESPECIFIC.DUPLICATES_T_IX_5 ON SITESPECIFIC.DUPLICATE_T
(LICENSETYPEJOBID)
LOGGING
TABLESPACE LARGE_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
