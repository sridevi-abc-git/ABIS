DROP INDEX SITESPECIFIC.OBJECTID;

CREATE UNIQUE INDEX SITESPECIFIC.OBJECTID ON SITESPECIFIC.FEESURCHARGESCHEDULE_T
(OBJECTID)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
