DROP INDEX SITESPECIFIC.DUPLICATE_T_PK;

CREATE UNIQUE INDEX SITESPECIFIC.DUPLICATE_T_PK ON SITESPECIFIC.DUPLICATE_T
(DUPLICATEID)
LOGGING
TABLESPACE LARGE_ENC_INDEX
PCTFREE    10
INITRANS   2
MAXTRANS   255
STORAGE    (
            INITIAL          64K
            NEXT             1M
            MINEXTENTS       1
            MAXEXTENTS       UNLIMITED
            PCTINCREASE      0
            BUFFER_POOL      DEFAULT
           );
