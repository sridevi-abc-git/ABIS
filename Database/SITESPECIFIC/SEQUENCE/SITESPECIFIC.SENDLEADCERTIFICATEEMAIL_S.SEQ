DROP SEQUENCE SITESPECIFIC.SENDLEADCERTIFICATEEMAIL_S;

CREATE SEQUENCE SITESPECIFIC.SENDLEADCERTIFICATEEMAIL_S
  START WITH 57579
  MAXVALUE 999999999999999999999999999
  MINVALUE 1
  NOCYCLE
  NOCACHE
  NOORDER
  NOKEEP
  NOSCALE
  GLOBAL;


GRANT SELECT ON SITESPECIFIC.SENDLEADCERTIFICATEEMAIL_S TO ABC;
