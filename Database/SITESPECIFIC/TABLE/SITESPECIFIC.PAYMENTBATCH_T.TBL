DROP TABLE SITESPECIFIC.PAYMENTBATCH_T CASCADE CONSTRAINTS;

CREATE GLOBAL TEMPORARY TABLE SITESPECIFIC.PAYMENTBATCH_T
(
  LICENSETYPEJOBID  NUMBER,
  LICENSENUMBER     VARCHAR2(10 BYTE),
  LICENSETYPECODE   VARCHAR2(3 BYTE),
  PAIDAMOUNT        NUMBER
)
ON COMMIT DELETE ROWS
NOCACHE;


GRANT DELETE, INSERT, SELECT, UPDATE ON SITESPECIFIC.PAYMENTBATCH_T TO POSSEEXTENSIONS;
