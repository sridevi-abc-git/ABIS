DROP TABLE SITESPECIFIC.LESSTHANZEROBALANCE_GT CASCADE CONSTRAINTS;

CREATE GLOBAL TEMPORARY TABLE SITESPECIFIC.LESSTHANZEROBALANCE_GT
(
  FILENUM            VARCHAR2(60 BYTE),
  STATUS             VARCHAR2(6 BYTE),
  DIST               VARCHAR2(2 BYTE),
  AMOUNTPAID         NUMBER,
  OVERPAYMENTAMOUNT  NUMBER
)
ON COMMIT DELETE ROWS
NOCACHE;


GRANT SELECT ON SITESPECIFIC.LESSTHANZEROBALANCE_GT TO POSSEEXTENSIONS;

GRANT SELECT ON SITESPECIFIC.LESSTHANZEROBALANCE_GT TO POSSESYS;
