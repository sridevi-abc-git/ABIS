DROP TABLE SITESPECIFIC.DEPOSITDETAILIDS_GT CASCADE CONSTRAINTS;

CREATE GLOBAL TEMPORARY TABLE SITESPECIFIC.DEPOSITDETAILIDS_GT
(
  AMOUNT                NUMBER,
  DEPOSITJOBID          NUMBER,
  FEEOBJECTID           NUMBER,
  PAYMENTOBJECTID       NUMBER,
  TRANSMITTALJOBID      NUMBER,
  PAYMENTTRANSOBJECTID  NUMBER
)
ON COMMIT DELETE ROWS
NOCACHE;


GRANT SELECT ON SITESPECIFIC.DEPOSITDETAILIDS_GT TO POSSEEXTENSIONS;
