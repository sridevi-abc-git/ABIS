           );

CREATE INDEX SITESPECIFIC.FEESCHEDULE_IX_3 ON SITESPECIFIC.FEESCHEDULE_T
(DESCRIPTION)
LOGGING
TABLESPACE SMALL_ENC_INDEX
PCTFREE    10
INITRANS   2
