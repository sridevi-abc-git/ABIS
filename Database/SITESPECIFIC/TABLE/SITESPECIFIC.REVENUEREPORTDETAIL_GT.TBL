DROP TABLE SITESPECIFIC.REVENUEREPORTDETAIL_GT CASCADE CONSTRAINTS;

CREATE GLOBAL TEMPORARY TABLE SITESPECIFIC.REVENUEREPORTDETAIL_GT
(
  REVENUECODE  VARCHAR2(10 BYTE),
  TRANSCODE    VARCHAR2(10 BYTE),
  LTCODE       VARCHAR2(10 BYTE),
  AMOUNT       NUMBER
)
ON COMMIT DELETE ROWS
NOCACHE;


GRANT SELECT ON SITESPECIFIC.REVENUEREPORTDETAIL_GT TO POSSEEXTENSIONS;
