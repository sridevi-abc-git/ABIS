DROP TABLE SITESPECIFIC.ALLOCATIONREPORTDETAIL_GT CASCADE CONSTRAINTS;

CREATE GLOBAL TEMPORARY TABLE SITESPECIFIC.ALLOCATIONREPORTDETAIL_GT
(
  ALLOCATIONCODE  VARCHAR2(30 BYTE),
  TRANSCODE       VARCHAR2(10 BYTE),
  LTCODE          VARCHAR2(10 BYTE),
  AMOUNT          NUMBER
)
ON COMMIT DELETE ROWS
NOCACHE;


GRANT DELETE, INSERT, SELECT, UPDATE ON SITESPECIFIC.ALLOCATIONREPORTDETAIL_GT TO ABCREPORTS;

GRANT SELECT ON SITESPECIFIC.ALLOCATIONREPORTDETAIL_GT TO POSSEEXTENSIONS;
